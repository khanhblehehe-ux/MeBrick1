# Template .env for backend (b/) — DO NOT COMMIT secrets to git
# Copy this file to .env and fill real values before running locally.

# Supabase project URL
SUPABASE_URL=

# Supabase service_role key (required for server-side privileged operations)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: allowlist of CORS origins (comma-separated)
# Example: CORS_ORIGINS=http://localhost:3000,https://example.com
CORS_ORIGINS=

# Port to run backend (default 5000)
PORT=5000

# Node environment
NODE_ENV=development

# Reminder: keep .env out of git (add b/.env to .gitignore if not present)
